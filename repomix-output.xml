## 8\. Row Level Security (RLS) Policies (Updated)

```sql
-- Enable RLS
ALTER TABLE users ENABLE ROW LEVEL SECURITY;
ALTER TABLE rooms ENABLE ROW LEVEL SECURITY;
ALTER TABLE reservations ENABLE ROW LEVEL SECURITY;
ALTER TABLE qr_login_sessions ENABLE ROW LEVEL SECURITY;

-- User Policies
CREATE POLICY "authenticated_view_active_users" ON users FOR SELECT TO authenticated
    USING (is_active = true);

CREATE POLICY "users_update_own_profile" ON users FOR UPDATE TO authenticated
    USING (auth.uid() = auth_id) WITH CHECK (auth.uid() = auth_id);

CREATE POLICY "authenticated_insert_users" ON users FOR INSERT TO authenticated
    WITH CHECK (true);

CREATE POLICY "admin_manage_all_users" ON users FOR ALL TO authenticated
    USING (
        EXISTS (
            SELECT 1 FROM users u
            WHERE u.auth_id = auth.uid() AND u.role = 'admin' AND u.is_active = true
        )
    );

-- Room Policies
CREATE POLICY "authenticated_view_rooms" ON rooms FOR SELECT TO authenticated
    USING (true);

CREATE POLICY "admin_manage_rooms" ON rooms FOR ALL TO authenticated
    USING (
        EXISTS (
            SELECT 1 FROM users u
            WHERE u.auth_id = auth.uid() AND u.role = 'admin' AND u.is_active = true
        )
    );

-- Reservation Policies
CREATE POLICY "authenticated_view_reservations" ON reservations FOR SELECT TO authenticated
    USING (true);

CREATE POLICY "users_manage_own_reservations" ON reservations FOR ALL TO authenticated
    USING (
        user_id IN (SELECT id FROM users WHERE auth_id = auth.uid())
    )
    WITH CHECK (
        user_id IN (SELECT id FROM users WHERE auth_id = auth.uid())
    );

CREATE POLICY "admin_manage_all_reservations" ON reservations FOR ALL TO authenticated
    USING (
        EXISTS (
            SELECT 1 FROM users u
            WHERE u.auth_id = auth.uid() AND u.role = 'admin' AND u.is_active = true
        )
    );

-- QR Session Policies (NEW)
CREATE POLICY "users_view_own_qr_sessions" ON qr_login_sessions FOR SELECT TO authenticated
    USING (
        user_id = (SELECT id FROM users WHERE auth_id = auth.uid())
    );

CREATE POLICY "admin_manage_all_qr_sessions" ON qr_login_sessions FOR ALL TO authenticated
    USING (
        EXISTS (
            SELECT 1 FROM users u
            WHERE u.auth_id = auth.uid() AND u.role = 'admin'
        )
    );
```

**주요 변경사항:**
