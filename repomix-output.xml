        console.log(`      체크: ${policy.with_check || '없음'}`);
      });
    } else {
      console.log('   ⚠️  설정된 RLS 정책이 없습니다.');
    }

    // 3. Auth 관련 테이블 확인
    console.log('\n3. Auth 스키마 테이블들:');
    const authTablesQuery = `
      SELECT table_name 
      FROM information_schema.tables 
      WHERE table_schema = 'auth' 
      ORDER BY table_name;
    `;

