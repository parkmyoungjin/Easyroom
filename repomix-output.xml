      .from('users')
      .select('count')
      .limit(1)
      .abortSignal(controller.signal);
    
    clearTimeout(timeoutId);
    return { success: !error, error };
  } catch (err) {
    clearTimeout(timeoutId);
    return { success: false, error: err.message };
  }
};
