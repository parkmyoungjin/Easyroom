    loading,
    error,
    authStatus,
    signIn,
    signOut,
    signUp,
    updateProfile,
    resendEmailConfirmation,
    checkEmailConfirmation,
    checkEmailExists,
    signInWithEmployeeId,
    signUpWithEmployeeId,
    requireAuth,
    hasPermission,
    isAdmin,
    isAuthenticated,
    isLoading,
    handlePostLoginRedirect,
    redirectToLogin,
    handlePostLogout,
  };
}
