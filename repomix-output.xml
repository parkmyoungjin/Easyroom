-- Function to fix individual reservation user_id
CREATE OR REPLACE FUNCTION fix_reservation_user_id(reservation_id UUID)
RETURNS BOOLEAN
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
DECLARE
    current_user_id UUID;
    correct_user_id UUID;
    user_name TEXT;
    reservation_title TEXT;
BEGIN
    -- Get current user_id from reservation
    SELECT user_id, title INTO current_user_id, reservation_title
    FROM public.reservations 
    WHERE id = reservation_id;
    
    IF current_user_id IS NULL THEN
        RAISE EXCEPTION 'Reservation not found: %', reservation_id;
    END IF;
    
    -- Check if current user_id is valid
    IF EXISTS (SELECT 1 FROM public.users WHERE id = current_user_id) THEN
        -- Already correct
        RETURN TRUE;
    END IF;
    
    -- Check if it's an auth_id that needs to be converted
    SELECT id, name INTO correct_user_id, user_name
    FROM public.users 
    WHERE auth_id = current_user_id;
    
    IF correct_user_id IS NULL THEN
        RAISE EXCEPTION 'Cannot fix reservation %: user_id % does not exist as either id or auth_id', 
                       reservation_id, current_user_id;
    END IF;
    
    -- Update the reservation with correct user_id
    UPDATE public.reservations 
    SET user_id = correct_user_id,
        updated_at = NOW()
    WHERE id = reservation_id;
    
    -- Log the fix
    RAISE NOTICE 'Fixed reservation % ("%"): changed user_id from % to % for user %', 
                 reservation_id, reservation_title, current_user_id, correct_user_id, user_name;
    
    RETURN TRUE;
END;
$$;

-- Function to batch fix all user_id inconsistencies
CREATE OR REPLACE FUNCTION fix_all_reservation_user_ids()
RETURNS TABLE (
    reservation_id UUID,
    old_user_id UUID,
    new_user_id UUID,
    user_name TEXT,
    reservation_title TEXT,
    fixed BOOLEAN
)
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
DECLARE
    rec RECORD;
    fix_count INTEGER := 0;
    error_count INTEGER := 0;
BEGIN
    -- Find all reservations with potential auth_id confusion
    FOR rec IN 
        SELECT r.id, r.user_id, r.title, u.id as correct_user_id, u.name
        FROM public.reservations r
        INNER JOIN public.users u ON r.user_id = u.auth_id
        WHERE r.user_id != u.id
    LOOP
        BEGIN
            -- Attempt to fix this reservation
            UPDATE public.reservations 
            SET user_id = rec.correct_user_id,
                updated_at = NOW()
            WHERE id = rec.id;
            
            -- Return success record
            reservation_id := rec.id;
            old_user_id := rec.user_id;
            new_user_id := rec.correct_user_id;
            user_name := rec.name;
            reservation_title := rec.title;
            fixed := TRUE;
            
            fix_count := fix_count + 1;
            RETURN NEXT;
            
        EXCEPTION WHEN OTHERS THEN
            -- Return error record
            reservation_id := rec.id;
            old_user_id := rec.user_id;
            new_user_id := rec.correct_user_id;
            user_name := rec.name;
            reservation_title := rec.title;
            fixed := FALSE;
            
            error_count := error_count + 1;
            RETURN NEXT;
        END;
    END LOOP;
    
    -- Log summary
    RAISE NOTICE 'Batch fix completed: % reservations fixed, % errors', fix_count, error_count;
END;
$$;

