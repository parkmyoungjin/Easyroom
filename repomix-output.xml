        password,
        user_metadata: userMetadata,
        email_confirm: true, // 이메일 확인 없이 바로 활성화
        phone_confirm: true  // 폰 확인 없이 바로 활성화
      });

      if (error) {
        console.error(`❌ ${userData.fullName} 생성 실패:`, error.message);
        
