      console.log('\n🎉 사용자 생성 완료!');
      console.log('이제 다음 계정으로 로그인할 수 있습니다:');
      console.log('- 관리자: 6666666 / pnuh6666666');
      console.log('- 직원: 1234567 / pnuh1234567');
    }

  } catch (error) {
    console.error('❌ 전체 과정 중 오류:', error);
  }
}

