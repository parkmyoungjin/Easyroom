    it('should benchmark multiple concurrent authentication requests', async () => {
      const concurrentRequests = 10;
      const authOperations = Array.from({ length: concurrentRequests }, (_, i) => 
        jest.fn().mockImplementation(() => 
          new Promise(resolve => {
