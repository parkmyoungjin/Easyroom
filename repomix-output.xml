  title, 
  subtitle,
  showBackButton = true,
  showHomeButton = false,
  onBack,
  rightContent,
}: MobileHeaderProps) {
  const router = useRouter();

  const handleBack = () => {
    // onBack prop이 있으면 그것을 우선 실행
