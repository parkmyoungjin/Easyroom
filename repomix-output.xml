-- Add pagination support to public reservations functions
-- This migration adds limit and offset parameters to existing functions
-- and creates new paginated versions with metadata

-- =============================================================================
-- ENHANCED PAGINATED FUNCTIONS
-- =============================================================================

-- Enhanced public reservations function with pagination for authenticated users
CREATE OR REPLACE FUNCTION get_public_reservations_paginated(
    start_date TIMESTAMPTZ,
    end_date TIMESTAMPTZ,
    page_limit INTEGER DEFAULT 50,
    page_offset INTEGER DEFAULT 0
)
RETURNS TABLE (
    id UUID,
    room_id UUID,
    user_id UUID,
    title TEXT,
    purpose TEXT,
    start_time TIMESTAMPTZ,
    end_time TIMESTAMPTZ,
    department TEXT,
    user_name TEXT,
    is_mine BOOLEAN,
    total_count BIGINT,
    has_more BOOLEAN
)
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
DECLARE
    current_user_db_id UUID;
    total_reservations BIGINT;
BEGIN
    -- Input validation
    PERFORM validate_reservation_date_range(start_date, end_date);
    
    -- Validate pagination parameters
    IF page_limit IS NULL OR page_limit <= 0 OR page_limit > 100 THEN
        RAISE EXCEPTION 'page_limit must be between 1 and 100';
    END IF;
    
    IF page_offset IS NULL OR page_offset < 0 THEN
        RAISE EXCEPTION 'page_offset must be >= 0';
    END IF;
    
    -- Get current user's database ID (NULL if not authenticated)
    SELECT u.id INTO current_user_db_id
    FROM public.users u
    WHERE u.auth_id = auth.uid();

    -- Get total count for pagination metadata
    SELECT COUNT(*) INTO total_reservations
    FROM public.reservations r
    INNER JOIN public.users u ON r.user_id = u.id
    INNER JOIN public.rooms rm ON r.room_id = rm.id
    WHERE r.status = 'confirmed'
        AND r.start_time < end_date
        AND r.end_time > start_date;

    -- Return paginated reservations with user context-based data masking
    RETURN QUERY
    SELECT 
        r.id,
        r.room_id,
        r.user_id,
        CASE 
            WHEN current_user_db_id IS NOT NULL AND r.user_id = current_user_db_id 
            THEN r.title::TEXT 
            ELSE 'Booked'::TEXT 
        END as title,
        CASE 
            WHEN current_user_db_id IS NOT NULL AND r.user_id = current_user_db_id 
            THEN r.purpose::TEXT 
            ELSE NULL::TEXT 
        END as purpose,
        r.start_time,
        r.end_time,
        u.department::TEXT as department,
        u.name::TEXT as user_name,
        CASE 
            WHEN current_user_db_id IS NOT NULL AND r.user_id = current_user_db_id 
            THEN TRUE 
            ELSE FALSE 
        END as is_mine,
        total_reservations as total_count,
        CASE 
            WHEN (page_offset + page_limit) < total_reservations 
            THEN TRUE 
            ELSE FALSE 
        END as has_more
    FROM public.reservations r
    INNER JOIN public.users u ON r.user_id = u.id
    INNER JOIN public.rooms rm ON r.room_id = rm.id
    WHERE r.status = 'confirmed'
        AND r.start_time < end_date
        AND r.end_time > start_date
    ORDER BY r.start_time ASC
    LIMIT page_limit
    OFFSET page_offset;
END;
$$;

