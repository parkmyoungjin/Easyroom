      width: "device-width",
      initialScale: 1,
    },
  };

  // ❌ DON'T: Incomplete metadata
  export const metadata = {
    title: "Meeting Room Booking", // Missing Korean
    description: "Book meeting rooms", // Missing Korean
  };
  ```

## Language Settings
- **HTML Lang Attribute**
  - Set `lang="ko"` in root layout
  - Use proper language codes
  ```typescript
  // ✅ DO: Proper language setting
  export default function RootLayout({
    children,
  }: {
    children: React.ReactNode;
  }) {
    return (
      <html lang="ko" suppressHydrationWarning>
        <body>{children}</body>
      </html>
    );
  }
  ```

## Date and Time Formatting
- **Use Korean Locale**
  - Import Korean locale from date-fns
  - Apply consistent date/time formats
  ```typescript
  // ✅ DO: Korean date formatting
  import { format } from "date-fns";
  import { ko } from "date-fns/locale";

  const formattedDate = format(date, "yyyy년 MM월 dd일", { locale: ko });
  const formattedTime = format(date, "HH:mm");

  // ❌ DON'T: Non-localized formats
  const wrongFormat = format(date, "MM/DD/YYYY");
  ```

## Error Messages
- **Consistent Korean Messages**
  - Use polite form (-습니다)
  - Keep messages clear and concise
  - Include action guidance when needed
  ```typescript
  // ✅ DO: Clear Korean messages
  const messages = {
    success: "저장되었습니다",
    error: "오류가 발생했습니다. 다시 시도해주세요",
    loading: "로딩 중입니다...",
  };

  // ❌ DON'T: Mixed language or informal messages
  const wrongMessages = {
    success: "Saved!",
    error: "에러 발생",
    loading: "Loading...",
  };
  ```

## Component Text
- **Text Content Guidelines**
  - Use consistent terminology
  - Maintain formal tone
  - Include proper spacing for Korean text
  ```typescript
  // ✅ DO: Proper Korean UI text
  <Button>
    예약하기
  </Button>
  <Label>
    회의 목적
  </Label>

  // ❌ DON'T: Inconsistent or mixed language
  <Button>
    BOOK NOW
  </Button>
  <Label>
    미팅Purpose
  </Label>
  ```

## Accessibility
- **Korean Screen Reader Support**
  - Use proper aria-labels in Korean
  - Include descriptive alt text
  ```typescript
  // ✅ DO: Accessible Korean text
  <Input
    aria-label="사번을 입력하세요"
    placeholder="사번"
  />
  <img
    src="/logo.png"
    alt="회의실 예약 시스템 로고"
