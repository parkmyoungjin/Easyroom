'use client';

import { createClient } from '@/lib/supabase/client';
import { UserProfile, UserMetadata } from '@/types/auth';

type LoginData = {
  employeeId: string;
  password: string;
};

type CreateUserData = {
  employeeId: string;
  fullName: string;
  department: string;
  role?: 'employee' | 'admin';
};

export const authService = {
  async createUser(userData: CreateUserData): Promise<UserProfile> {
    // ✅ 서버 API 호출로 사용자 생성
    const response = await fetch('/api/auth/signup', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(userData),
    });

    if (!response.ok) {
      const error = await response.json();
      throw new Error(error.error || '회원가입에 실패했습니다');
    }

    const { user } = await response.json();
    return user;
  },

  async login(data: LoginData): Promise<UserProfile> {
    // ✅ 서버 API 호출로 로그인 처리
    const response = await fetch('/api/auth/login', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(data),
    });

    if (!response.ok) {
      const error = await response.json();
      throw new Error(error.error || '로그인에 실패했습니다');
    }

    const { user } = await response.json();
    return user;
  },

  async logout(): Promise<void> {
    // ✅ 서버 API 호출로 로그아웃 처리
    const response = await fetch('/api/auth/logout', {
      method: 'POST',
    });

    if (!response.ok) {
      console.error('Logout API failed, but continuing with client logout');
    }

    // 클라이언트에서도 로그아웃 처리
    const supabase = createClient();
    await supabase.auth.signOut();
  },

  async getCurrentUser(): Promise<UserProfile | null> {
    const supabase = createClient();
    const { data: { session } } = await supabase.auth.getSession();
    
    if (!session?.user) return null;

    // user_metadata에서 camelCase로 프로필 생성
    const metadata = session.user.user_metadata as UserMetadata || {};
    
    return {
      id: session.user.id,
      authId: session.user.id, // camelCase로 수정
      employeeId: metadata.employeeId || '',
      email: session.user.email || '',
      name: metadata.fullName || '',
      department: metadata.department || '',
      role: metadata.role || 'employee',
      createdAt: session.user.created_at || '',
      updatedAt: session.user.updated_at
    };
  },

  async isAdmin(): Promise<boolean> {
    const user = await this.getCurrentUser();
    return user?.role === 'admin';
  },

  async updateProfile(updates: Partial<Pick<UserMetadata, 'fullName' | 'department' | 'role'>>): Promise<UserProfile> {
    const supabase = createClient();
    
    const { data, error } = await supabase.auth.updateUser({
      data: updates
    });

    if (error) {
      throw error;
    }

    if (!data.user) {
      throw new Error('프로필 업데이트에 실패했습니다');
    }

    // 업데이트된 프로필 반환
    const metadata = data.user.user_metadata as UserMetadata || {};
    
    return {
      id: data.user.id,
      authId: data.user.id, // camelCase로 수정
      employeeId: metadata.employeeId || '',
      email: data.user.email || '',
      name: metadata.fullName || '',
      department: metadata.department || '',
      role: metadata.role || 'employee',
      createdAt: data.user.created_at || '',
      updatedAt: data.user.updated_at
    };
  }
};
