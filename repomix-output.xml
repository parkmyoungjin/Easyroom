    ({ limit, offset }) => fetchPaginatedPublicReservations(
      startDate, 
      endDate, 
      isAuthenticated, 
      { 
        limit, 
        offset, 
        sortOrder: 'asc' as const
      }
    ),
    {
      limit: options?.limit || 20,
      enabled: options?.enabled !== false && !!startDate && !!endDate,
      staleTime: 5 * 60 * 1000,
      gcTime: 10 * 60 * 1000,
    }
  );
