    it('should prevent NoSQL injection in RPC function calls', async () => {
      const mockUser = { id: 'user-123' };
      mockSupabase.auth.getUser.mockResolvedValue({
        data: { user: mockUser },
        error: null
      });

      // Mock RPC function to simulate injection attempt
