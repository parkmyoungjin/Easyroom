    (deploymentIntegration.removeUpdateListener as jest.Mock).mockImplementation(mockRemoveListener);

    const { unmount } = render(<TestComponent />);
    
    unmount();

    expect(mockRemoveListener).toHaveBeenCalled();
  });
});
