-- View for monitoring user_id consistency
CREATE OR REPLACE VIEW reservation_user_id_health AS
SELECT 
    'Total Reservations' as metric,
    COUNT(*)::text as value,
    'All reservations in system' as description
FROM public.reservations

UNION ALL

SELECT 
    'Valid User ID References' as metric,
    COUNT(*)::text as value,
    'Reservations with correct user_id references' as description
FROM public.reservations r
INNER JOIN public.users u ON r.user_id = u.id

UNION ALL

SELECT 
    'Potential Auth ID Confusion' as metric,
    COUNT(*)::text as value,
    'Reservations possibly using auth_id instead of db id' as description
FROM public.reservations r
INNER JOIN public.users u ON r.user_id = u.auth_id
WHERE r.user_id != u.id

UNION ALL

SELECT 
    'Orphaned Reservations' as metric,
    COUNT(*)::text as value,
    'Reservations with invalid user_id references' as description
FROM public.reservations r
LEFT JOIN public.users u ON r.user_id = u.id
WHERE u.id IS NULL;

