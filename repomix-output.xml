                  <Button type="submit" className="flex-1" disabled={isPending}>
                    {isPending ? "예약 중..." : "예약하기"}
                  </Button>
                </div>
              </form>
            </Form>
          </CardContent>
        </Card>
      </div>
    </div>
  );
}
