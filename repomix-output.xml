    -- Update the reservation with correct user_id
    UPDATE reservations 
    SET user_id = correct_user_id,
        updated_at = NOW()
    WHERE id = reservation_id;
    
    -- Log the fix
    RAISE NOTICE 'Fixed reservation % ("%"): changed user_id from % to % for user %', 
                 reservation_id, reservation_title, current_user_id, correct_user_id, user_name;
    
    RETURN TRUE;
END;
$;

-- 7. Create function to batch fix all user_id inconsistencies
CREATE OR REPLACE FUNCTION fix_all_reservation_user_ids()
RETURNS TABLE (
    reservation_id UUID,
    old_user_id UUID,
    new_user_id UUID,
    user_name TEXT,
    reservation_title TEXT,
    fixed BOOLEAN
)
LANGUAGE plpgsql
SECURITY DEFINER
AS $
DECLARE
    rec RECORD;
    fix_count INTEGER := 0;
    error_count INTEGER := 0;
BEGIN
    -- Find all reservations with potential auth_id confusion
    FOR rec IN 
        SELECT r.id, r.user_id, r.title, u.id as correct_user_id, u.name
        FROM reservations r
        INNER JOIN users u ON r.user_id = u.auth_id
        WHERE r.user_id != u.id
    LOOP
        BEGIN
            -- Attempt to fix this reservation
            UPDATE reservations 
            SET user_id = rec.correct_user_id,
                updated_at = NOW()
            WHERE id = rec.id;
            
            -- Return success record
            reservation_id := rec.id;
            old_user_id := rec.user_id;
            new_user_id := rec.correct_user_id;
            user_name := rec.name;
            reservation_title := rec.title;
            fixed := TRUE;
            
            fix_count := fix_count + 1;
            RETURN NEXT;
            
        EXCEPTION WHEN OTHERS THEN
            -- Return error record
            reservation_id := rec.id;
            old_user_id := rec.user_id;
            new_user_id := rec.correct_user_id;
            user_name := rec.name;
            reservation_title := rec.title;
            fixed := FALSE;
            
            error_count := error_count + 1;
            RETURN NEXT;
        END;
    END LOOP;
    
    -- Log summary
    RAISE NOTICE 'Batch fix completed: % reservations fixed, % errors', fix_count, error_count;
END;
$;

-- 8. Grant execute permissions
GRANT EXECUTE ON FUNCTION validate_user_id_reference() TO authenticated;
GRANT EXECUTE ON FUNCTION fix_reservation_user_id(UUID) TO authenticated;
GRANT EXECUTE ON FUNCTION fix_all_reservation_user_ids() TO authenticated;

-- 9. Create index for performance on user_id lookups
CREATE INDEX IF NOT EXISTS idx_reservations_user_id_performance 
ON reservations(user_id) 
WHERE status = 'confirmed';

-- 10. Add comments for documentation
COMMENT ON FUNCTION validate_user_id_reference IS 
'Trigger function that validates user_id references users.id (not auth_id) on reservation insert/update';

COMMENT ON FUNCTION fix_reservation_user_id IS 
'Fixes a single reservation user_id if it incorrectly references auth_id instead of database id';

COMMENT ON FUNCTION fix_all_reservation_user_ids IS 
'Batch fixes all reservations that incorrectly use auth_id instead of database user_id';

COMMENT ON CONSTRAINT reservations_user_id_format_check ON reservations IS 
'Ensures user_id is a valid UUID format';

COMMENT ON CONSTRAINT reservations_room_id_format_check ON reservations IS 
'Ensures room_id is a valid UUID format';

-- 11. Create view for monitoring user_id consistency
CREATE OR REPLACE VIEW reservation_user_id_health AS
SELECT 
    'Total Reservations' as metric,
    COUNT(*)::text as value,
    'All reservations in system' as description
FROM reservations

UNION ALL

SELECT 
    'Valid User ID References' as metric,
    COUNT(*)::text as value,
    'Reservations with correct user_id references' as description
FROM reservations r
INNER JOIN users u ON r.user_id = u.id

UNION ALL

SELECT 
    'Potential Auth ID Confusion' as metric,
    COUNT(*)::text as value,
    'Reservations possibly using auth_id instead of db id' as description
FROM reservations r
INNER JOIN users u ON r.user_id = u.auth_id
WHERE r.user_id != u.id

UNION ALL

SELECT 
    'Orphaned Reservations' as metric,
    COUNT(*)::text as value,
    'Reservations with invalid user_id references' as description
FROM reservations r
LEFT JOIN users u ON r.user_id = u.id
WHERE u.id IS NULL;

-- Grant access to the monitoring view
GRANT SELECT ON reservation_user_id_health TO authenticated;

COMMENT ON VIEW reservation_user_id_health IS 
'Monitoring view for reservation user_id consistency health metrics';

-- 12. Log migration completion
DO $
BEGIN
    RAISE NOTICE 'User ID consistency constraints migration completed:';
    RAISE NOTICE '- Added validation trigger for user_id references';
    RAISE NOTICE '- Added UUID format check constraints';
    RAISE NOTICE '- Strengthened foreign key constraints';
    RAISE NOTICE '- Created repair functions for fixing inconsistencies';
    RAISE NOTICE '- Added monitoring view for health checks';
    RAISE NOTICE '- All future reservations will be validated for correct user_id usage';
END $;
</file>

