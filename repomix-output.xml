  console.log('\n' + '='.repeat(60));
  console.log(`📊 통합 테스트 결과: ${passedTests}/${tests.length} 통과`);
  
  if (passedTests === tests.length) {
    console.log('🎉 모든 통합 테스트 통과! 시스템이 완전히 안정적입니다.');
