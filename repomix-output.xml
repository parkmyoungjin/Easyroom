    it('should work with pagination parameters', async () => {
      const mockData = [
        {
          id: 'res1',
          title: 'My Meeting',
          is_mine: true
        }
      ];

      mockSupabase.rpc.mockResolvedValue({ data: mockData, error: null });

      const result = await mockSupabase.rpc('get_public_reservations', {
