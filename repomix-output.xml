    });
  });

  describe('POST Endpoint Validation', () => {
    it('should validate reservation creation data', async () => {
      const mockHandler = jest.fn().mockResolvedValue(
        NextResponse.json({ id: 'new-reservation-id', message: 'Created' }, { status: 201 })
      );

