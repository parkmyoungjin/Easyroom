        <button onClick={dismissUpdate}>Dismiss</button>
        <button onClick={checkForUpdates}>Check Updates</button>
      </div>
    );
  };

  beforeEach(() => {
    jest.clearAllMocks();
    mockReload.mockClear();
  });

  it('should initialize with no update', () => {
