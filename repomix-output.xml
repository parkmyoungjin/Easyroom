          total_pages: 3
        }
      };

      expect(mockResponse.data).toBeDefined();
      expect(mockResponse.pagination).toBeDefined();
      expect(mockResponse.pagination.limit).toBe(10);
      expect(mockResponse.pagination.total_count).toBe(25);
