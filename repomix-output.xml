  } else {
    console.log('⚠️  일부 통합 테스트 실패. 위의 오류를 확인하세요.');
  }
  
  console.log('\n💡 시스템 현황:');
  console.log('- Auth 시스템: ✅ 완전 작동 (Admin API 사용)');
