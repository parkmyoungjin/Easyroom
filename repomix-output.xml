<file path="src/app/api/auth/login/route.ts">
import { createClient } from '@/lib/supabase/server';
import { NextRequest, NextResponse } from 'next/server';
import { z } from 'zod';
import { logger } from '@/lib/utils/logger';
import { UserMetadata } from '@/types/auth';

const loginSchema = z.object({
  employeeId: z.string().min(1),
  password: z.string().min(1),
});

export async function POST(request: NextRequest) {
  try {
    console.log('=== Login API 시작 ===');
    
    const body = await request.json();
    const { employeeId, password } = loginSchema.parse(body);

    logger.server.info('Login attempt started (Supabase Auth)', { employeeId });
    console.log('로그인 시도:', { employeeId, password: password.substring(0, 4) + '***' });

    const supabase = await createClient();

    // ✅ Supabase Auth 사용 - 이메일과 비밀번호로 로그인
    const email = `${employeeId}@company.com`;
    console.log('로그인 이메일:', email);
    
    const { data: authData, error: authError } = await supabase.auth.signInWithPassword({
      email,
      password,
    });

    if (authError) {
      console.error('Supabase Auth 로그인 에러:', authError);
      logger.server.error('Supabase Auth login failed', { 
        employeeId, 
        error: authError?.message 
      });
      return NextResponse.json(
        { error: `로그인에 실패했습니다: ${authError.message}` },
        { status: 401 }
      );
    }

    if (!authData?.user) {
      console.error('사용자 데이터가 없음');
      return NextResponse.json(
        { error: '로그인에 실패했습니다. 사용자 정보를 찾을 수 없습니다.' },
        { status: 401 }
      );
    }

    // 📝 user_metadata에서 camelCase로 데이터 추출
    const user = authData.user;
    const userMetadata = user.user_metadata as UserMetadata || {};
    
    console.log('사용자 메타데이터:', userMetadata);

    // 🎉 로그인 성공 - camelCase 형태로 사용자 정보 반환
    logger.server.info('Supabase Auth login successful', { 
      employeeId, 
      userId: user.id,
      email: user.email,
      fullName: userMetadata.fullName
    });

    const response = NextResponse.json({ 
      user: {
        id: user.id,
        authId: user.id, // camelCase로 수정
        employeeId: userMetadata.employeeId || employeeId,
        email: user.email,
        name: userMetadata.fullName || '', // fullName을 name으로 매핑
        department: userMetadata.department || '',
        role: userMetadata.role || 'employee',
        createdAt: user.created_at,
        updatedAt: user.updated_at
      },
      session: {
        accessToken: authData.session?.access_token,
        refreshToken: authData.session?.refresh_token,
        expiresAt: authData.session?.expires_at
      },
      message: '로그인 성공'
    });

    // Supabase 세션 쿠키 설정 (Supabase가 자동으로 처리)
    if (authData.session) {
      response.cookies.set('supabase-auth-token', authData.session.access_token, {
        httpOnly: true,
        secure: process.env.NODE_ENV === 'production',
        sameSite: 'strict',
        maxAge: authData.session.expires_in || 3600
      });
    }

    console.log('✅ 로그인 성공');
    return response;

  } catch (error) {
    const errorMessage = error instanceof Error ? error.message : String(error);
    const errorStack = error instanceof Error ? error.stack : undefined;
    
    console.error('=== Login API 에러 ===');
    console.error('에러 상세:', error);
    console.error('에러 스택:', errorStack);
    
    logger.server.error('Login API unexpected error', { error: errorMessage, stack: errorStack });
    return NextResponse.json(
      { error: `로그인 중 오류가 발생했습니다: ${errorMessage}` },
      { status: 500 }
    );
  }
}
</file>

