/**
 * Monitoring Dashboard API Endpoint
 * 모니터링 대시보드용 실시간 데이터 제공
 */

import { NextRequest, NextResponse } from 'next/server';
import { monitoring } from '@/lib/monitoring/integration';
import { securityMonitor } from '@/lib/monitoring/security-monitor';
import { performanceMonitor } from '@/lib/monitoring/performance-monitor';
import { logger } from '@/lib/utils/logger';

export interface DashboardData {
  timestamp: string;
  summary: {
    status: 'healthy' | 'degraded' | 'critical';
    totalAlerts: number;
    criticalAlerts: number;
    systemUptime: number;
  };
  security: {
    recentEvents: {
      total: number;
      byType: Record<string, number>;
      bySeverity: Record<string, number>;
    };
    activeAlerts: Array<{
      id: string;
      type: string;
      severity: string;
      count: number;
      firstOccurrence: string;
      lastOccurrence: string;
    }>;
    topThreats: Array<{
      type: string;
      count: number;
      severity: string;
      trend: 'increasing' | 'decreasing' | 'stable';
    }>;
  };
  performance: {
    overview: {
      averageResponseTime: number;
      successRate: number;
      totalOperations: number;
      slowOperations: number;
    };
    byOperation: Record<string, {
      count: number;
      averageDuration: number;
      successRate: number;
      p95Duration: number;
    }>;
    trends: {
      responseTime: Array<{
        timestamp: string;
        value: number;
      }>;
      throughput: Array<{
        timestamp: string;
        value: number;
      }>;
    };
  };
  system: {
    resources: {
      memoryUsage: number;
      monitoringLoad: number;
    };
    health: {
      database: 'healthy' | 'degraded' | 'unhealthy';
      environment: 'healthy' | 'degraded' | 'unhealthy';
      security: 'healthy' | 'degraded' | 'unhealthy';
    };
  };
  alerts: Array<{
    id: string;
    type: 'security' | 'performance' | 'system';
    severity: 'low' | 'medium' | 'high' | 'critical';
    title: string;
    message: string;
    timestamp: string;
    acknowledged: boolean;
  }>;
}

/**
 * 모니터링 대시보드 데이터 제공
 */
export async function GET(request: NextRequest): Promise<NextResponse> {
  try {
    const { searchParams } = new URL(request.url);
    const timeWindow = parseInt(searchParams.get('timeWindow') || '60', 10); // 기본 1시간
    const includeDetails = searchParams.get('details') === 'true';

    logger.debug('대시보드 데이터 요청', { timeWindow, includeDetails });

    // 기본 모니터링 데이터 수집
    const dashboardData = monitoring.getDashboardData();
    
    // 추가 상세 데이터 수집
    const securityStats = securityMonitor.getSecurityStats(timeWindow);
    const performanceStats = performanceMonitor.getPerformanceStats(timeWindow);
    const activeSecurityAlerts = securityMonitor.getActiveAlerts();
    const performanceAlerts = performanceMonitor.getPerformanceAlerts(20);
    const systemHealth = securityMonitor.getSystemHealth();
    const resourceUsage = performanceMonitor.getResourceUsage();

    // 보안 위협 분석
    const topThreats = analyzeTopThreats(securityStats.eventsByType, timeWindow);
    
    // 성능 트렌드 데이터
    const performanceTrends = generatePerformanceTrends(timeWindow);
    
    // 통합 알림 목록
    const combinedAlerts = combineAlerts(activeSecurityAlerts, performanceAlerts);

    // 전체 시스템 상태 결정
    const overallStatus = determineOverallStatus(
      systemHealth.status,
      activeSecurityAlerts.length,
      performanceStats.averageDuration
    );

    const result: DashboardData = {
      timestamp: new Date().toISOString(),
      summary: {
        status: overallStatus,
        totalAlerts: activeSecurityAlerts.length + performanceAlerts.filter(a => a.severity === 'critical').length,
        criticalAlerts: activeSecurityAlerts.filter(a => a.severity === 'critical').length + 
                       performanceAlerts.filter(a => a.severity === 'critical').length,
        systemUptime: Math.floor(process.uptime())
      },
      security: {
        recentEvents: {
          total: securityStats.totalEvents,
          byType: securityStats.eventsByType,
          bySeverity: securityStats.eventsBySeverity
        },
        activeAlerts: activeSecurityAlerts.map(alert => ({
          id: alert.id,
          type: alert.eventType,
          severity: alert.severity,
          count: alert.count,
          firstOccurrence: alert.firstOccurrence,
          lastOccurrence: alert.lastOccurrence
        })),
        topThreats
      },
      performance: {
        overview: {
          averageResponseTime: Math.round(performanceStats.averageDuration),
          successRate: Math.round(performanceStats.successRate * 100) / 100,
          totalOperations: performanceStats.totalOperations,
          slowOperations: performanceStats.slowestOperations.length
        },
        byOperation: performanceStats.operationStats,
        trends: performanceTrends
      },
      system: {
        resources: {
          memoryUsage: Math.round(resourceUsage.memoryUsage * 100),
          monitoringLoad: Math.round((resourceUsage.metricsCount / 50000) * 100) // 최대 메트릭 수 대비
        },
        health: {
          database: 'healthy', // 실제로는 헬스체크 결과 사용
          environment: 'healthy',
          security: systemHealth.status === 'healthy' ? 'healthy' : 
                   systemHealth.status === 'degraded' ? 'degraded' : 'unhealthy'
        }
      },
      alerts: combinedAlerts
    };

    // 상세 정보 포함 여부에 따른 응답 조정
    if (!includeDetails) {
      // 기본 정보만 포함
      delete (result.performance as any).byOperation;
      delete (result.performance as any).trends;
      result.security.activeAlerts = result.security.activeAlerts.slice(0, 5);
      result.alerts = result.alerts.slice(0, 10);
    }

    return NextResponse.json(result);

  } catch (error) {
    logger.error('대시보드 데이터 수집 실패', { error });
    
    return NextResponse.json(
      { 
        error: 'Failed to retrieve dashboard data',
        timestamp: new Date().toISOString()
      },
      { status: 500 }
    );
  }
}

/**
 * 상위 보안 위협 분석
 */
function analyzeTopThreats(eventsByType: Record<string, number>, timeWindow: number): Array<{
  type: string;
  count: number;
  severity: string;
  trend: 'increasing' | 'decreasing' | 'stable';
}> {
  const recentEvents = securityMonitor.getRecentEvents(1000);
  const now = new Date();
  const windowStart = new Date(now.getTime() - timeWindow * 60 * 1000);
  const halfWindowStart = new Date(now.getTime() - (timeWindow / 2) * 60 * 1000);

  return Object.entries(eventsByType)
    .map(([type, count]) => {
      // 트렌드 분석을 위해 시간 창을 반으로 나누어 비교
      const firstHalfEvents = recentEvents.filter(e => 
        e.type === type &&
        new Date(e.timestamp) >= windowStart &&
        new Date(e.timestamp) < halfWindowStart
      ).length;

      const secondHalfEvents = recentEvents.filter(e => 
        e.type === type &&
        new Date(e.timestamp) >= halfWindowStart
      ).length;

      let trend: 'increasing' | 'decreasing' | 'stable' = 'stable';
      if (secondHalfEvents > firstHalfEvents * 1.5) {
        trend = 'increasing';
      } else if (secondHalfEvents < firstHalfEvents * 0.5) {
        trend = 'decreasing';
      }

      // 심각도 결정
      const typeEvents = recentEvents.filter(e => e.type === type);
      const avgSeverity = typeEvents.length > 0 ? 
        typeEvents.reduce((sum, e) => {
          const severityScore = { low: 1, medium: 2, high: 3, critical: 4 }[e.severity] || 1;
          return sum + severityScore;
        }, 0) / typeEvents.length : 1;

      const severity = avgSeverity >= 3.5 ? 'critical' :
                      avgSeverity >= 2.5 ? 'high' :
                      avgSeverity >= 1.5 ? 'medium' : 'low';

      return { type, count, severity, trend };
    })
    .sort((a, b) => b.count - a.count)
    .slice(0, 5);
}

/**
 * 성능 트렌드 데이터 생성
 */
function generatePerformanceTrends(timeWindow: number): {
  responseTime: Array<{ timestamp: string; value: number }>;
  throughput: Array<{ timestamp: string; value: number }>;
} {
  const trends = performanceMonitor.getPerformanceTrends(undefined, Math.ceil(timeWindow / 60));
  
  const responseTime = trends.hourlyAverages.map(hour => ({
    timestamp: hour.hour,
    value: Math.round(hour.averageDuration)
  }));

  const throughput = trends.hourlyAverages.map(hour => ({
    timestamp: hour.hour,
    value: hour.operationCount
  }));

  return { responseTime, throughput };
}

/**
 * 보안 및 성능 알림 통합
 */
function combineAlerts(securityAlerts: any[], performanceAlerts: any[]): Array<{
  id: string;
  type: 'security' | 'performance' | 'system';
  severity: 'low' | 'medium' | 'high' | 'critical';
  title: string;
  message: string;
  timestamp: string;
  acknowledged: boolean;
}> {
  const combined: any[] = [];

  // 보안 알림 변환
  securityAlerts.forEach(alert => {
    combined.push({
      id: alert.id,
      type: 'security',
      severity: alert.severity,
      title: `Security Alert: ${alert.eventType}`,
      message: `${alert.count} occurrences detected in ${alert.timeWindow} minutes`,
      timestamp: alert.lastOccurrence,
      acknowledged: false
    });
  });

  // 성능 알림 변환
  performanceAlerts.forEach(alert => {
    combined.push({
      id: alert.id,
      type: 'performance',
      severity: alert.severity,
      title: `Performance Alert: ${alert.operation}`,
      message: `Response time ${Math.round(alert.actualValue)}ms exceeded threshold ${alert.threshold}ms`,
      timestamp: alert.timestamp,
      acknowledged: false
    });
  });

  // 시간순 정렬 (최신 순)
  return combined
    .sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime())
    .slice(0, 20);
}

/**
 * 전체 시스템 상태 결정
 */
function determineOverallStatus(
  securityStatus: string,
  activeAlertsCount: number,
  avgResponseTime: number
): 'healthy' | 'degraded' | 'critical' {
  if (securityStatus === 'critical' || avgResponseTime > 5000) {
    return 'critical';
  }
  
  if (securityStatus === 'degraded' || activeAlertsCount > 5 || avgResponseTime > 2000) {
    return 'degraded';
  }
  
  return 'healthy';
}

/**
 * 실시간 메트릭 스트림 (Server-Sent Events)
 */
export async function POST(request: NextRequest): Promise<NextResponse> {
  try {
    const { action } = await request.json();
    
    if (action === 'acknowledge_alert') {
      const { alertId } = await request.json();
      
      // 알림 확인 처리
      const resolved = securityMonitor.resolveAlert(alertId);
      
      return NextResponse.json({ 
        success: resolved,
        message: resolved ? 'Alert acknowledged' : 'Alert not found'
      });
    }
    
    if (action === 'get_realtime_metrics') {
      // 실시간 메트릭 반환
      const realtimeData = {
        timestamp: new Date().toISOString(),
        activeConnections: 0, // 실제 구현에서는 연결 수 추적
        currentLoad: Math.round(process.cpuUsage().user / 1000),
        memoryUsage: Math.round(process.memoryUsage().heapUsed / 1024 / 1024),
        recentEvents: securityMonitor.getRecentEvents(10),
        systemHealth: securityMonitor.getSystemHealth()
      };
      
      return NextResponse.json(realtimeData);
    }
    
    return NextResponse.json({ error: 'Unknown action' }, { status: 400 });
    
  } catch (error) {
    logger.error('대시보드 액션 처리 실패', { error });
    
    return NextResponse.json(
      { error: 'Failed to process dashboard action' },
      { status: 500 }
    );
  }
}
