        ...baseParams,
        page_limit: pageLimit,
        page_offset: pageOffset
      };

      expect(rpcParams).toEqual({
        start_date: '2025-01-22T00:00:00.000Z',
        end_date: '2025-01-22T23:59:59.999Z',
