} from '@/lib/monitoring/environment-monitor';

// Mock dependencies
jest.mock('@/lib/utils/logger');
jest.mock('@/lib/monitoring/security-monitor');

describe('Environment Monitor', () => {
  let mockContext: EnvironmentErrorContext;

