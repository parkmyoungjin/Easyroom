<file path="supabase/migrations/20250121000000_email_auth_migration.sql">
-- Email Authentication Migration
-- 기존 사번 기반 인증에서 이메일 기반 인증으로 마이그레이션
-- 기존 테이블 구조 유지하되 이메일 인증 지원을 위한 최소 변경

-- 1. users 테이블 스키마 업데이트
-- employee_id를 nullable로 변경 (기존 호환성 유지)
ALTER TABLE public.users 
ALTER COLUMN employee_id DROP NOT NULL;

-- 2. 기존 데이터 정합성 확인을 위한 제약조건 추가
-- auth_id가 반드시 존재해야 함 (Supabase Auth 연동 필수)
ALTER TABLE public.users 
ALTER COLUMN auth_id SET NOT NULL;

-- 3. 이메일 필드가 반드시 존재해야 함
ALTER TABLE public.users 
ALTER COLUMN email SET NOT NULL;

-- 4. 인덱스 최적화 (기존 인덱스 유지)
-- auth_id 인덱스는 이미 존재하므로 확인만 수행
DO $
BEGIN
    IF NOT EXISTS (
        SELECT 1 FROM pg_indexes 
        WHERE tablename = 'users' 
        AND indexname = 'idx_users_auth_id'
    ) THEN
        CREATE INDEX idx_users_auth_id ON public.users(auth_id);
    END IF;
END $;

-- 5. 이메일 인덱스 추가 (성능 최적화)
DO $
BEGIN
    IF NOT EXISTS (
        SELECT 1 FROM pg_indexes 
        WHERE tablename = 'users' 
        AND indexname = 'idx_users_email'
    ) THEN
        CREATE INDEX idx_users_email ON public.users(email);
    END IF;
END $;

-- 6. RLS 정책 업데이트 (기존 정책 유지)
-- 기존 정책들이 이미 auth_id 기반으로 작동하므로 변경 불필요

-- 7. 데이터 검증 함수 생성
CREATE OR REPLACE FUNCTION validate_user_auth_integration()
RETURNS BOOLEAN
LANGUAGE plpgsql
SECURITY DEFINER
AS $
BEGIN
    -- auth_id가 실제 auth.users와 연결되어 있는지 확인
    IF EXISTS (
        SELECT 1 FROM public.users u
        LEFT JOIN auth.users au ON u.auth_id = au.id
        WHERE au.id IS NULL
    ) THEN
        RAISE EXCEPTION 'auth_id 연결이 끊어진 사용자가 존재합니다.';
        RETURN FALSE;
    END IF;
    
    -- 이메일 중복 확인
    IF EXISTS (
        SELECT email FROM public.users
        GROUP BY email
        HAVING COUNT(*) > 1
    ) THEN
        RAISE EXCEPTION '중복된 이메일이 존재합니다.';
        RETURN FALSE;
    END IF;
    
    RETURN TRUE;
END;
$;

-- 8. 마이그레이션 검증 실행
SELECT validate_user_auth_integration();

-- 9. 기존 함수들 호환성 확인
-- get_public_reservations 함수는 이미 auth_id 기반으로 작동하므로 변경 불필요

-- 10. 마이그레이션 완료 로그
DO $
BEGIN
    RAISE NOTICE '이메일 인증 마이그레이션이 완료되었습니다.';
    RAISE NOTICE '- employee_id: nullable로 변경됨';
    RAISE NOTICE '- auth_id: NOT NULL 제약조건 확인됨';
    RAISE NOTICE '- email: NOT NULL 제약조건 확인됨';
    RAISE NOTICE '- 인덱스: auth_id, email 인덱스 확인됨';
    RAISE NOTICE '- RLS 정책: 기존 정책 유지됨';
    RAISE NOTICE '- 기존 함수: 호환성 유지됨';
END $;

-- 마이그레이션 메타데이터
COMMENT ON TABLE public.users IS '사용자 정보 테이블 - 이메일 인증 지원 (employee_id는 선택사항)';
</file>

<file path="supabase/migrations/20250716201146_fix_rpc_function_exact_types.sql">
-- Fix RPC function with exact database schema types
-- PostgreSQL 타입 시스템과 정확히 일치하도록 수정

-- 기존 함수 완전 제거
DROP FUNCTION IF EXISTS get_public_reservations CASCADE;

-- 실제 데이터베이스 스키마와 정확히 일치하는 타입으로 함수 생성
CREATE OR REPLACE FUNCTION get_public_reservations(
  start_date TIMESTAMPTZ,
  end_date TIMESTAMPTZ
)
RETURNS TABLE (
  id UUID,
  room_id UUID,
  user_id UUID,
  title TEXT,
  purpose TEXT,
  start_time TIMESTAMPTZ,
  end_time TIMESTAMPTZ,
  department TEXT,
  user_name TEXT,
  is_mine BOOLEAN
)
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
DECLARE
  current_user_db_id UUID;
BEGIN
  -- 현재 인증된 사용자의 데이터베이스 ID 조회 (인증되지 않은 경우 NULL)
  SELECT u.id INTO current_user_db_id
  FROM users u
  WHERE u.auth_id = auth.uid();

  -- 예약 목록 반환 (is_mine 필드 포함)
  -- 모든 VARCHAR 타입을 TEXT로 명시적 캐스팅
  RETURN QUERY
  SELECT 
    r.id,
    r.room_id,
    r.user_id,
    CASE 
      WHEN current_user_db_id IS NOT NULL AND r.user_id = current_user_db_id 
      THEN r.title::TEXT 
      ELSE 'Booked'::TEXT 
    END as title,
    CASE 
      WHEN current_user_db_id IS NOT NULL AND r.user_id = current_user_db_id 
      THEN r.purpose::TEXT 
      ELSE NULL::TEXT 
    END as purpose,
    r.start_time,
    r.end_time,
    u.department::TEXT as department,
    u.name::TEXT as user_name,
    CASE 
      WHEN current_user_db_id IS NOT NULL AND r.user_id = current_user_db_id 
      THEN TRUE 
      ELSE FALSE 
    END as is_mine
  FROM reservations r
  INNER JOIN users u ON r.user_id = u.id
  INNER JOIN rooms rm ON r.room_id = rm.id
  WHERE r.status = 'confirmed'
    AND r.start_time < end_date
    AND r.end_time > start_date
  ORDER BY r.start_time ASC;
END;
$$;

-- RPC 함수 실행 권한 부여 (인증된 사용자와 익명 사용자 모두)
GRANT EXECUTE ON FUNCTION get_public_reservations(TIMESTAMPTZ, TIMESTAMPTZ) TO authenticated;
GRANT EXECUTE ON FUNCTION get_public_reservations(TIMESTAMPTZ, TIMESTAMPTZ) TO anon;
</file>

<file path="supabase/migrations/README.md">
# Database Migrations

이 디렉터리는 Supabase 데이터베이스 마이그레이션 파일들을 포함합니다.

## 📋 Current Migration Files (통합된 버전)

| 파일명 | 날짜 | 상태 | 설명 |
|--------|------|------|------|
| `00000000000000_initial_schema.sql` | - | ✅ **기본 스키마** | 통합된 초기 데이터베이스 스키마 |
| `20250121000000_email_auth_migration.sql` | 2025-01-21 | ✅ **운영중** | 이메일 기반 인증 시스템 설정 |
| `20250122000000_create_anonymous_public_reservations_function.sql` | 2025-01-22 | ✅ **운영중** | 비인증 사용자용 공개 예약 RPC 함수 |
| `20250122000001_enhance_rpc_security_model.sql` | 2025-01-22 | ✅ **운영중** | RPC 함수 보안 모델 강화 (입력 검증 추가) |
| `20250122000002_add_user_id_consistency_constraints.sql` | 2025-01-22 | ✅ **운영중** | 사용자 ID 일관성 제약조건 추가 |
| `20250716201146_fix_rpc_function_exact_types.sql` | 2025-07-16 | ✅ **운영중** | 인증 사용자용 공개 예약 RPC 함수 (최종 버전) |

## 🎯 Current System Status

### Authentication System
- **방식**: 이메일 기반 인증 (Supabase Auth)
- **사용자 테이블**: `public.users` 테이블에 `auth_id`로 연결
- **역할**: `employee`, `admin` 역할 지원

### RPC Functions
- **`get_public_reservations(start_date, end_date)`**: 인증된 사용자용
  - 자신의 예약: 전체 정보 표시
  - 다른 사용자 예약: "Booked"로 마스킹
  - 입력 검증 포함 (날짜 범위 제한)

- **`get_public_reservations_anonymous(start_date, end_date)`**: 비인증 사용자용
  - 모든 예약: "Booked"로 마스킹
  - 최소한의 공개 정보만 제공
  - 입력 검증 포함

- **`validate_reservation_date_range(start_date, end_date)`**: 입력 검증 함수
  - 날짜 범위 검증 (최대 90일)
  - 과거/미래 제한 (30일 전 ~ 1년 후)
  - SQL 인젝션 방지

### Security Features
- **RLS 정책**: Row Level Security 적용
- **입력 검증**: 모든 RPC 함수에 파라미터 검증
- **데이터 마스킹**: 사용자 컨텍스트 기반 정보 제한
- **접근 제어**: 인증 상태별 차등 정보 제공

## 🔧 Development Guidelines

### 새로운 마이그레이션 생성 시
1. **Migration Manager 사용**: `node scripts/migration-manager.js create "description"`
2. 날짜 기반 파일명 사용: `YYYYMMDDHHMMSS_description.sql`
3. 기존 함수 수정 시 `CREATE OR REPLACE` 사용
4. 권한 설정 포함 (`GRANT EXECUTE`)
5. 적절한 주석과 문서화 추가
6. 마이그레이션 전 검증: `node scripts/migration-manager.js validate`

### 보안 고려사항
- `SECURITY DEFINER` 함수는 최소한의 로직만 포함
- 모든 입력 파라미터 검증 필수
- 민감한 정보는 사용자 컨텍스트 기반 마스킹
- RLS 정책과 조합하여 다중 보안 계층 구성

### Migration Manager 사용법
```bash
# 마이그레이션 목록 확인
node scripts/migration-manager.js list

# 새 마이그레이션 생성
node scripts/migration-manager.js create "add new feature"

# 마이그레이션 검증
node scripts/migration-manager.js validate

# 상태 보고서 생성
node scripts/migration-manager.js report

# 테스트 (dry run)
node scripts/migration-manager.js test
```

## 📚 Migration History

이전 버전의 마이그레이션 파일들은 정리되었으며, 현재 운영 중인 시스템에 필요한 파일들만 유지됩니다.

### 정리된 파일들 (아카이브됨)
- `20250716192239_create_get_public_reservations_function.sql` - 초기 버전
- `20250716195116_fix_get_public_reservations_return_types.sql` - 중간 수정 버전
- `20250716202015_migration_cleanup_documentation.sql` - 문서화 파일
- `20250121000001_add_user_own_reservations_policy.sql` - 중복 정책 파일

현재 시스템은 안정적으로 운영되고 있으며, 모든 보안 요구사항을 충족합니다.
</file>

