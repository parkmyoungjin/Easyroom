/**
 * Health Check API Endpoint
 * 시스템 상태 확인 및 모니터링 엔드포인트
 */

import { NextRequest, NextResponse } from 'next/server';
import { createClient } from '@/lib/supabase/server';
import { environmentManager } from '@/lib/security/environment-manager';
import { securityMonitor } from '@/lib/monitoring/security-monitor';
import { performanceMonitor } from '@/lib/monitoring/performance-monitor';
import { logger } from '@/lib/utils/logger';

export interface HealthCheckResult {
  status: 'healthy' | 'degraded' | 'unhealthy';
  timestamp: string;
  version?: string;
  checks: {
    database: HealthCheck;
    environment: HealthCheck;
    security: HealthCheck;
    performance: HealthCheck;
    rls_policies: HealthCheck;
  };
  summary: {
    total: number;
    passed: number;
    failed: number;
    warnings: number;
  };
}

export interface HealthCheck {
  status: 'pass' | 'fail' | 'warn';
  duration: number;
  message: string;
  details?: Record<string, any>;
  lastChecked: string;
}

/**
 * 전체 시스템 상태 확인
 */
export async function GET(request: NextRequest): Promise<NextResponse> {
  const startTime = performance.now();
  const timestamp = new Date().toISOString();
  
  logger.info('시스템 상태 확인 시작');

  try {
    // 각 구성 요소 상태 확인
    const [
      databaseCheck,
      environmentCheck,
      securityCheck,
      performanceCheck,
      rlsPolicyCheck
    ] = await Promise.allSettled([
      checkDatabaseHealth(),
      checkEnvironmentHealth(),
      checkSecurityHealth(),
      checkPerformanceHealth(),
      checkRlsPolicyHealth()
    ]);

    // 결과 정리
    const checks = {
      database: getCheckResult(databaseCheck),
      environment: getCheckResult(environmentCheck),
      security: getCheckResult(securityCheck),
      performance: getCheckResult(performanceCheck),
      rls_policies: getCheckResult(rlsPolicyCheck)
    };

    // 전체 상태 결정
    const checkValues = Object.values(checks);
    const failedChecks = checkValues.filter(c => c.status === 'fail').length;
    const warningChecks = checkValues.filter(c => c.status === 'warn').length;
    
    let overallStatus: 'healthy' | 'degraded' | 'unhealthy';
    if (failedChecks > 0) {
      overallStatus = 'unhealthy';
    } else if (warningChecks > 0) {
      overallStatus = 'degraded';
    } else {
      overallStatus = 'healthy';
    }

    const result: HealthCheckResult = {
      status: overallStatus,
      timestamp,
      version: process.env.npm_package_version || '1.0.0',
      checks,
      summary: {
        total: checkValues.length,
        passed: checkValues.filter(c => c.status === 'pass').length,
        failed: failedChecks,
        warnings: warningChecks
      }
    };

    const totalDuration = performance.now() - startTime;
    
    logger.info('시스템 상태 확인 완료', {
      status: overallStatus,
      duration: Math.round(totalDuration),
      summary: result.summary
    });

    // 상태에 따른 HTTP 상태 코드 설정
    const httpStatus = overallStatus === 'healthy' ? 200 : 
                     overallStatus === 'degraded' ? 200 : 503;

    return NextResponse.json(result, { status: httpStatus });

  } catch (error) {
    logger.error('시스템 상태 확인 실패', { error });
    
    const errorResult: HealthCheckResult = {
      status: 'unhealthy',
      timestamp,
      checks: {
        database: createFailedCheck('Database check failed', error),
        environment: createFailedCheck('Environment check failed', error),
        security: createFailedCheck('Security check failed', error),
        performance: createFailedCheck('Performance check failed', error),
        rls_policies: createFailedCheck('RLS policy check failed', error)
      },
      summary: {
        total: 5,
        passed: 0,
        failed: 5,
        warnings: 0
      }
    };

    return NextResponse.json(errorResult, { status: 503 });
  }
}

/**
 * 데이터베이스 연결 및 기본 쿼리 상태 확인
 */
async function checkDatabaseHealth(): Promise<HealthCheck> {
  const startTime = performance.now();
  
  try {
    const supabase = await createClient();
    
    // 기본 연결 테스트
    const { data, error } = await supabase
      .from('users')
      .select('count')
      .limit(1);

    if (error) {
      throw new Error(`Database query failed: ${error.message}`);
    }

    // 연결 풀 상태 확인 (가능한 경우)
    const connectionTest = await supabase
      .rpc('get_public_reservations_anonymous', {
        start_date: new Date().toISOString(),
        end_date: new Date(Date.now() + 60000).toISOString()
      });

    const duration = performance.now() - startTime;
    
    return {
      status: 'pass',
      duration: Math.round(duration),
      message: 'Database connection healthy',
      details: {
        connectionTime: Math.round(duration),
        rpcFunctionWorking: !connectionTest.error
      },
      lastChecked: new Date().toISOString()
    };

  } catch (error) {
    const duration = performance.now() - startTime;
    
    return {
      status: 'fail',
      duration: Math.round(duration),
      message: `Database health check failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
      lastChecked: new Date().toISOString()
    };
  }
}

/**
 * 환경 변수 및 구성 상태 확인
 */
async function checkEnvironmentHealth(): Promise<HealthCheck> {
  const startTime = performance.now();
  
  try {
    // 환경 변수 검증
    const validation = environmentManager.validateEnvironment();
    
    const duration = performance.now() - startTime;
    
    if (!validation.valid) {
      return {
        status: 'fail',
        duration: Math.round(duration),
        message: 'Environment validation failed',
        details: {
          errors: validation.errors,
          warnings: validation.warnings
        },
        lastChecked: new Date().toISOString()
      };
    }

    const status = validation.warnings.length > 0 ? 'warn' : 'pass';
    
    return {
      status,
      duration: Math.round(duration),
      message: validation.warnings.length > 0 
        ? 'Environment validation passed with warnings'
        : 'Environment validation passed',
      details: {
        warnings: validation.warnings,
        checkedVariables: [
          'NEXT_PUBLIC_SUPABASE_URL',
          'NEXT_PUBLIC_SUPABASE_ANON_KEY',
          'SUPABASE_SERVICE_ROLE_KEY'
        ]
      },
      lastChecked: new Date().toISOString()
    };

  } catch (error) {
    const duration = performance.now() - startTime;
    
    return {
      status: 'fail',
      duration: Math.round(duration),
      message: `Environment check failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
      lastChecked: new Date().toISOString()
    };
  }
}

/**
 * 보안 모니터링 시스템 상태 확인
 */
async function checkSecurityHealth(): Promise<HealthCheck> {
  const startTime = performance.now();
  
  try {
    const systemHealth = securityMonitor.getSystemHealth();
    const activeAlerts = securityMonitor.getActiveAlerts();
    const recentStats = securityMonitor.getSecurityStats(60); // 지난 1시간
    
    const duration = performance.now() - startTime;
    
    let status: 'pass' | 'warn' | 'fail';
    let message: string;
    
    if (systemHealth.status === 'critical') {
      status = 'fail';
      message = 'Critical security alerts detected';
    } else if (systemHealth.status === 'degraded' || activeAlerts.length > 5) {
      status = 'warn';
      message = 'Security system degraded or multiple alerts active';
    } else {
      status = 'pass';
      message = 'Security monitoring system healthy';
    }
    
    return {
      status,
      duration: Math.round(duration),
      message,
      details: {
        systemStatus: systemHealth.status,
        activeAlerts: activeAlerts.length,
        recentEvents: recentStats.totalEvents,
        memoryUsage: systemHealth.memoryUsage,
        lastEventTime: systemHealth.lastEventTime
      },
      lastChecked: new Date().toISOString()
    };

  } catch (error) {
    const duration = performance.now() - startTime;
    
    return {
      status: 'fail',
      duration: Math.round(duration),
      message: `Security health check failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
      lastChecked: new Date().toISOString()
    };
  }
}

/**
 * 성능 모니터링 시스템 상태 확인
 */
async function checkPerformanceHealth(): Promise<HealthCheck> {
  const startTime = performance.now();
  
  try {
    const performanceStats = performanceMonitor.getPerformanceStats(60);
    const resourceUsage = performanceMonitor.getResourceUsage();
    const performanceAlerts = performanceMonitor.getPerformanceAlerts(10);
    
    const duration = performance.now() - startTime;
    
    let status: 'pass' | 'warn' | 'fail';
    let message: string;
    
    const criticalAlerts = performanceAlerts.filter(a => a.severity === 'critical').length;
    const avgDuration = performanceStats.averageDuration;
    
    if (criticalAlerts > 0 || avgDuration > 5000) {
      status = 'fail';
      message = 'Critical performance issues detected';
    } else if (avgDuration > 2000 || resourceUsage.memoryUsage > 0.8) {
      status = 'warn';
      message = 'Performance degradation detected';
    } else {
      status = 'pass';
      message = 'Performance monitoring system healthy';
    }
    
    return {
      status,
      duration: Math.round(duration),
      message,
      details: {
        averageDuration: Math.round(avgDuration),
        successRate: Math.round(performanceStats.successRate * 100) / 100,
        totalOperations: performanceStats.totalOperations,
        memoryUsage: Math.round(resourceUsage.memoryUsage * 100),
        recentAlerts: performanceAlerts.length
      },
      lastChecked: new Date().toISOString()
    };

  } catch (error) {
    const duration = performance.now() - startTime;
    
    return {
      status: 'fail',
      duration: Math.round(duration),
      message: `Performance health check failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
      lastChecked: new Date().toISOString()
    };
  }
}

/**
 * RLS 정책 및 데이터베이스 보안 경계 확인
 */
async function checkRlsPolicyHealth(): Promise<HealthCheck> {
  const startTime = performance.now();
  
  try {
    const supabase = await createClient();
    
    // RLS 정책 테스트 - 익명 사용자로 제한된 데이터만 접근 가능한지 확인
    const anonymousTest = await supabase
      .rpc('get_public_reservations_anonymous', {
        start_date: new Date().toISOString(),
        end_date: new Date(Date.now() + 86400000).toISOString() // 24시간 후
      });

    // 기본 테이블 접근 테스트 (RLS가 적용되어야 함)
    const directTableTest = await supabase
      .from('reservations')
      .select('id, title, user_id')
      .limit(1);

    const duration = performance.now() - startTime;
    
    let status: 'pass' | 'warn' | 'fail' = 'pass';
    let message = 'RLS policies functioning correctly';
    const details: Record<string, any> = {
      anonymousRpcWorking: !anonymousTest.error,
      directTableAccessRestricted: true // RLS should restrict direct access
    };

    // RPC 함수가 작동하지 않으면 경고
    if (anonymousTest.error) {
      status = 'warn';
      message = 'RPC function access issues detected';
      details.rpcError = anonymousTest.error.message;
    }

    // 직접 테이블 접근이 너무 많은 데이터를 반환하면 RLS 문제 가능성
    if (directTableTest.data && directTableTest.data.length > 0) {
      // 익명 사용자가 직접 테이블에서 데이터를 가져올 수 있다면 RLS 문제
      const hasPersonalData = directTableTest.data.some(item => 
        item.title && item.title !== 'Booked'
      );
      
      if (hasPersonalData) {
        status = 'fail';
        message = 'RLS policy violation detected - personal data exposed';
        details.rlsViolation = true;
      }
    }
    
    return {
      status,
      duration: Math.round(duration),
      message,
      details,
      lastChecked: new Date().toISOString()
    };

  } catch (error) {
    const duration = performance.now() - startTime;
    
    return {
      status: 'fail',
      duration: Math.round(duration),
      message: `RLS policy check failed: ${error instanceof Error ? error.message : 'Unknown error'}`,
      lastChecked: new Date().toISOString()
    };
  }
}

/**
 * Promise.allSettled 결과를 HealthCheck로 변환
 */
function getCheckResult(settledResult: PromiseSettledResult<HealthCheck>): HealthCheck {
  if (settledResult.status === 'fulfilled') {
    return settledResult.value;
  } else {
    return createFailedCheck('Check execution failed', settledResult.reason);
  }
}

/**
 * 실패한 체크 결과 생성
 */
function createFailedCheck(message: string, error: any): HealthCheck {
  return {
    status: 'fail',
    duration: 0,
    message,
    details: {
      error: error instanceof Error ? error.message : String(error)
    },
    lastChecked: new Date().toISOString()
  };
}
