    it('should fail validation for production config without exit on validation failure', () => {
      process.env.NODE_ENV = 'production';
      const invalidConfig = {
        ...productionConfig,
        errorHandling: {
          ...productionConfig.errorHandling,
          exitOnValidationFailure: false
        }
