    const redirectPath = urlParams.get('redirect');
    window.location.href = redirectPath && redirectPath.startsWith('/') ? redirectPath : '/';
  }, []);

  const redirectToLogin = useCallback((currentPath?: string) => {
    if (typeof window === 'undefined') return;
